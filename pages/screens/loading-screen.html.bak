                <div class="dna-track"><div class="dna-fill dna-yt" id="bar-yt"></div></div>
                <span class="dna-pct" id="pct-yt">0%</span>
              </div>
              <div class="dna-row">
                <span class="dna-icon">📖</span>
                <span class="dna-name">Nhân văn</span>
                <div class="dna-track"><div class="dna-fill dna-nv" id="bar-nv"></div></div>
                <span class="dna-pct" id="pct-nv">0%</span>
              </div>
              <div class="dna-row">
                <span class="dna-icon">🌾</span>
                <span class="dna-name">Nông nghiệp</span>
                <div class="dna-track"><div class="dna-fill dna-nn" id="bar-nn"></div></div>
                <span class="dna-pct" id="pct-nn">0%</span>
              </div>
              <div class="dna-row">
                <span class="dna-icon">🌐</span>
                <span class="dna-name">Khoa học XH</span>
                <div class="dna-track"><div class="dna-fill dna-xh" id="bar-xh"></div></div>
