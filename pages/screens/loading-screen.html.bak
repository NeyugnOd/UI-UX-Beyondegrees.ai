            <div class="orbit orbit-4"><div class="particle p-nn"></div></div>
            <div class="orbit orbit-5"><div class="particle p-xh"></div></div>
            <div class="orbit orbit-6"><div class="particle p-tn"></div></div>
          </div>

          <!-- Phase text -->
          <div class="phase-wrap">
            <p class="phase-label" id="phaseLabel">Đang phân tích</p>
            <h2 class="phase-title" id="phaseTitle">DNA học thuật của bạn</h2>
          </div>

          <!-- Countdown + progress row -->
