            <div class="ff-dots" id="ffDots">
              <span class="ff-dot active"></span>
              <span class="ff-dot"></span>
              <span class="ff-dot"></span>
              <span class="ff-dot"></span>
              <span class="ff-dot"></span>
              <span class="ff-dot"></span>
            </div>
          </div>

        </div><!-- /loading-body -->

        <!-- ░░ MILESTONE TOAST ░░ -->
        <div class="milestone-toast" id="milestoneToast">
          <span class="ms-emoji" id="msEmoji">🔥</span>
