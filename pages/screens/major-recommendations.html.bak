<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Major Recommendations — BeyonDegrees.ai</title>
  <link rel="stylesheet" href="../../styles/tokens.css">
  <link rel="stylesheet" href="../../styles/base.css">
  <link rel="stylesheet" href="../../styles/components.css">
  <link rel="stylesheet" href="../../styles/animations.css">
  <link rel="stylesheet" href="../../styles/layout.css">
  <link rel="stylesheet" href="./major-recommendations.css">
</head>
<body>
<div class="breadcrumb"><a href="#" class="breadcrumb-item">BeyonDegrees-UI</a><span class="breadcrumb-separator">/</span><span class="breadcrumb-item active">Major Recommendations</span></div>
<div class="desktop-container">
  <div class="device-frame"><div class="device-notch"></div>
    <div class="mobile-screen"><div class="ms">
      <div class="ms-aurora"></div>
      <div class="ms-status"><span>9:41</span>
        <div style="display:flex;gap:6px;align-items:center">
          <svg width="14" height="10" viewBox="0 0 14 10" fill="currentColor"><rect x="0" y="3" width="2" height="7" rx="1"/><rect x="3" y="2" width="2" height="8" rx="1"/><rect x="6" y="0" width="2" height="10" rx="1"/><rect x="9" y="1" width="2" height="9" rx="1"/></svg>
          <svg width="16" height="10" viewBox="0 0 16 10" fill="currentColor"><rect x="1" y="1" width="11" height="8" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><rect x="2.5" y="2.5" width="7" height="5" rx="1"/><rect x="13" y="3" width="2" height="4" rx="1"/></svg>
        </div>
      </div>
      <div class="ms-hdr">
        <div class="ms-logo">Beyond<span>Degrees</span>.ai</div>
        <div style="width:30px;height:30px;border-radius:8px;background:var(--bg-surface);border:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
      </div>
      <div class="ms-body">
        <div class="demand">&#128293; High Demand</div>
        <div class="ms-hl">Majors Made<br>For You</div>
        <p class="ms-sub">These programs fit your strengths and career goals.</p>
        <div class="hero-maj">
          <div class="hm-top">
            <div class="hm-name">Artificial<br>Intelligence</div>
            <div><div class="hm-pct">98%</div><div class="hm-lbl">Compatibility</div></div>
          </div>
          <div class="hm-tags">
            <span class="hm-tag">#325 YR</span><span class="hm-tag v">Advanced</span><span class="hm-tag n">Math-Logic</span>
          </div>
          <div class="hm-cta">View Career Paths &#8594;</div>
        </div>
        <div class="sec-lbl">Other Top Matches</div>
        <div class="ml-item">
          <div class="ml-left"><div class="ml-ico">&#128202;</div><div><div class="ml-name">Data Science</div><div class="ml-sub">Analysis &amp; Insights</div></div></div>
          <div style="display:flex;align-items:center;gap:4px"><span class="ml-pct">94%</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg></div>
        </div>
        <div class="ml-item">
          <div class="ml-left"><div class="ml-ico">&#128187;</div><div><div class="ml-name">Software Engineering</div><div class="ml-sub">Development</div></div></div>
          <div style="display:flex;align-items:center;gap:4px"><span class="ml-pct">91%</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg></div>
        </div>
        <div class="ml-item">
          <div class="ml-left"><div class="ml-ico">&#128272;</div><div><div class="ml-name">Cybersecurity</div><div class="ml-sub">Hacking</div></div></div>
          <div style="display:flex;align-items:center;gap:4px"><span class="ml-pct">88%</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg></div>
        </div>
      </div>
        <div style="padding:12px 20px 6px;">
          <a href="#" onclick="(function(){try{sessionStorage.setItem('bd_nextStart','21');}catch(e){}window.location.href='./quiz-card.html?start=21';})();return false;" style="display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:14px 20px;background:linear-gradient(135deg,#7c3aed,#8b5cf6);color:#fff;border-radius:999px;font-size:15px;font-weight:700;text-decoration:none;letter-spacing:0.01em;box-shadow:0 4px 20px rgba(124,58,237,.45);">
            Tiếp tục Quiz &#8594;
          </a>
        </div>
        <!-- ░░ PRESS-GLOW FLOATING TAB BAR ░░ -->
        <nav class="float-tab-bar" id="floatTabBar">

          <a href="./home-screen.html" class="tab-item" data-tab="t1">
            <span class="tab-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="8" r="3.5"/><path d="M4 21c0-3.5 3.1-6 7-6s7 2.5 7 6"/><path d="M19 2l.45 1.35L20.8 3.8l-1.35.45L19 5.6l-.45-1.35L17.2 3.8l1.35-.45z" fill="currentColor" stroke="none"/>
              </svg>
            </span>
            <span class="tab-label">About me</span>
          </a>
          <a href="./discipline-match.html" class="tab-item" data-tab="t2">
            <span class="tab-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"/><polygon points="16.24,7.76 14.12,14.12 7.76,16.24 9.88,9.88" stroke="none" fill="currentColor" opacity="0.6"/><circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>
              </svg>
            </span>
            <span class="tab-label">Disciplines</span>
          </a>
          <a href="./major-recommendations.html" class="tab-item active" data-tab="t3">
            <span class="tab-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </span>
            <span class="tab-label">Majors</span>
          </a>
          <a href="./university-matches.html" class="tab-item" data-tab="t4">
            <span class="tab-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11M20 10v11M8 14v3M12 14v3M16 14v3"/>
              </svg>
            </span>
            <span class="tab-label">Universities</span>
          </a>
          <a href="#" class="tab-item tab-disabled" data-tab="t5">
            <span class="tab-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="7.5" r="3.5"/><path d="M4.5 20.5c0-3.5 3.4-6.5 7.5-6.5s7.5 3 7.5 6.5"/><circle cx="19" cy="5" r="2.5" fill="currentColor" stroke="none" opacity="0.9"/><path d="M18 5l.7.7 1.3-1.4" stroke="var(--bg-base,#06060f)" stroke-width="1.4" fill="none" stroke-linecap="round"/>
              </svg>
            </span>
            <span class="tab-label">Hoàng Phúc</span>
          </a>
        </nav>
      </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>