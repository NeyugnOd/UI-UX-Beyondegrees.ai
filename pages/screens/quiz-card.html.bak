<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quiz Card — BeyonDegrees.ai</title>
  <link rel="stylesheet" href="../../styles/tokens.css">
  <link rel="stylesheet" href="../../styles/base.css">
  <link rel="stylesheet" href="../../styles/components.css">
  <link rel="stylesheet" href="../../styles/animations.css">
  <link rel="stylesheet" href="./quiz-card.css">

<style>

/* ═══════════════════════════════════════════════════════════════════════════
   BEYONDEGREES.AI — THEME SYSTEM v1.0
   Dark (default) | Light | System
   Violet → Brand Blue #1863DC migration applied in dark mode
   ═══════════════════════════════════════════════════════════════════════════ */

/* ── DARK MODE: map violet palette → official brand blue ── */
:root,
:root[data-theme="dark"] {
  --violet-950: #06091A;
  --violet-900: #0A0F28;
  --violet-800: #0F2060;
  --violet-700: #1358C4;
  --violet-600: #1863DC;
  --violet-500: #0274BE;
  --violet-400: #6BA3FF;
  --violet-300: #93BBFF;
  --violet-200: #B8D4FF;
  --violet-100: #DCE9FF;
  --shadow-violet:    0 8px 24px rgba(24, 99, 220, 0.35);
  --shadow-violet-sm: 0 4px 12px rgba(24, 99, 220, 0.20);
  --glow-violet:      0 20px 50px rgba(24, 99, 220, 0.40);
  --glow-violet-sm:   0 12px 30px rgba(24, 99, 220, 0.28);
}

/* ── LIGHT MODE: official BeyonDegrees brand palette ── */
:root[data-theme="light"] {
  /* Brand blue stays — all other palette flips to light */
  --violet-600: #1863DC;
  --violet-500: #0274BE;
  --violet-400: #1863DC;
  --violet-300: #4A90E2;
  --violet-200: #93BBFF;
  --violet-100: #EEF4FB;
  --shadow-violet:    0 8px 24px rgba(24, 99, 220, 0.18);
  --shadow-violet-sm: 0 4px 12px rgba(24, 99, 220, 0.10);
  --glow-violet:      0 20px 50px rgba(24, 99, 220, 0.20);
  --glow-violet-sm:   0 12px 30px rgba(24, 99, 220, 0.15);

  /* Neutral scale flips */
  --neutral-950: #FFFFFF;
  --neutral-900: #F2F7FD;
  --neutral-800: #E0ECFA;
  --neutral-700: #C5D5E8;
  --neutral-600: #A8BDD8;
  --neutral-500: #808DAA;
  --neutral-400: #5A6580;
  --neutral-300: #3A3A4A;
  --neutral-200: #1A1A2E;
  --neutral-100: #0D0D1A;
  --neutral-50:  #060610;

  /* Semantic background tokens */
  --bg-base:     #FFFFFF;
  --bg-surface:  #F2F7FD;
  --bg-elevated: #E0ECFA;
  --bg-overlay:  #C5D5E8;

  /* Text tokens */
  --text-primary:   #1A1A2E;
  --text-secondary: #3A3A4A;
  --text-muted:     #808285;
  --text-disabled:  #C0C0D0;

  /* Mint stays readable on light bg */
  --mint-500: #059669;
  --mint-400: #10B981;
  --mint-300: #34D399;

  /* Orange */
  --orange-500: #D95F02;
  --orange-400: #F97316;
}

/* ── LIGHT MODE: body & global overrides ── */
[data-theme="light"] body {
  background: linear-gradient(135deg, #FFFFFF 0%, #EEF4FB 55%, #FFFFFF 100%) !important;
  color: #1A1A2E !important;
}

/* Hardcoded violet rgba chips → blue */
[data-theme="light"] [style*="rgba(124, 58, 237"],
[data-theme="light"] [style*="rgba(124,58,237"] {
  background: rgba(24, 99, 220, 0.12) !important;
  border-color: rgba(24, 99, 220, 0.25) !important;
  color: #1863DC !important;
}

/* Cards → white glass */
[data-theme="light"] .card,
[data-theme="light"] [class*="card"],
[data-theme="light"] .quiz-card,
[data-theme="light"] .result-card,
[data-theme="light"] .discipline-card,
[data-theme="light"] .major-card,
[data-theme="light"] .uni-card,
[data-theme="light"] .option-card,
[data-theme="light"] .stat-card,
[data-theme="light"] .info-card,
[data-theme="light"] .feature-card {
  background: rgba(255, 255, 255, 0.92) !important;
  border-color: rgba(24, 99, 220, 0.15) !important;
  box-shadow: 0 4px 24px rgba(24, 99, 220, 0.10) !important;
  color: #1A1A2E !important;
}
[data-theme="light"] .card:hover,
[data-theme="light"] [class*="card"]:hover {
  border-color: rgba(24, 99, 220, 0.35) !important;
  box-shadow: 0 12px 40px rgba(24, 99, 220, 0.18) !important;
}

/* Nav / header / tab-bar */
[data-theme="light"] nav,
[data-theme="light"] header,
[data-theme="light"] .nav-bar,
[data-theme="light"] .tab-bar,
[data-theme="light"] .top-nav,
[data-theme="light"] .header {
  background: rgba(255, 255, 255, 0.96) !important;
  border-color: rgba(24, 99, 220, 0.12) !important;
  box-shadow: 0 2px 16px rgba(24, 99, 220, 0.08) !important;
}

/* Tab items / nav links */
[data-theme="light"] .tab-item,
[data-theme="light"] .nav-link,
[data-theme="light"] .nav-item {
  color: #808285 !important;
}
[data-theme="light"] .tab-item.active,
[data-theme="light"] .nav-link.active,
[data-theme="light"] .tab-item:hover {
  color: #1863DC !important;
}

/* Chips & tags */
[data-theme="light"] .chip,
[data-theme="light"] [class*="chip"],
[data-theme="light"] [class*="tag"],
[data-theme="light"] .badge {
  background: rgba(24, 99, 220, 0.10) !important;
  border-color: rgba(24, 99, 220, 0.25) !important;
  color: #1863DC !important;
}
[data-theme="light"] [class*="chip-mint"],
[data-theme="light"] [class*="tag-mint"],
[data-theme="light"] [class*="chip-success"] {
  background: rgba(5, 150, 105, 0.12) !important;
  border-color: rgba(5, 150, 105, 0.30) !important;
  color: #059669 !important;
}

/* Dividers */
[data-theme="light"] .divider,
[data-theme="light"] hr {
  background: rgba(24, 99, 220, 0.12) !important;
}

/* Inputs */
[data-theme="light"] input,
[data-theme="light"] textarea,
[data-theme="light"] .input {
  background: #FFFFFF !important;
  border-color: rgba(24, 99, 220, 0.20) !important;
  color: #1A1A2E !important;
}
[data-theme="light"] input::placeholder,
[data-theme="light"] textarea::placeholder {
  color: #A0A0B0 !important;
}
[data-theme="light"] input:focus,
[data-theme="light"] textarea:focus {
  border-color: #1863DC !important;
  box-shadow: 0 0 0 3px rgba(24,99,220,0.15) !important;
}

/* Buttons: primary stays blue, ghost adapts */
[data-theme="light"] .btn-ghost,
[data-theme="light"] [class*="btn-ghost"] {
  background: rgba(24, 99, 220, 0.08) !important;
  border-color: rgba(24, 99, 220, 0.20) !important;
  color: #1863DC !important;
}
[data-theme="light"] .btn-ghost:hover {
  background: rgba(24, 99, 220, 0.14) !important;
}

/* Background orbs — soften for light mode */
[data-theme="light"] .bg-orb,
[data-theme="light"] [class*="orb"] {
  opacity: 0.35 !important;
}

/* Progress bars */
[data-theme="light"] .progress,
[data-theme="light"] [class*="progress-track"],
[data-theme="light"] [class*="progress-bg"] {
  background: rgba(24, 99, 220, 0.12) !important;
}

/* Breadcrumb */
[data-theme="light"] .breadcrumb-item { color: #808285 !important; }
[data-theme="light"] .breadcrumb-item:hover,
[data-theme="light"] .breadcrumb-item.active { color: #1863DC !important; }

/* Text elements that may be hardcoded white */
[data-theme="light"] h1,
[data-theme="light"] h2,
[data-theme="light"] h3,
[data-theme="light"] h4 {
  color: #1A1A2E;
}
[data-theme="light"] p,
[data-theme="light"] li,
[data-theme="light"] label,
[data-theme="light"] td,
[data-theme="light"] th {
  color: #3A3A4A;
}

/* ── TRANSITION: smooth theme switch ── */
*, *::before, *::after {
  transition: background-color 0.3s ease, border-color 0.3s ease, color 0.2s ease, box-shadow 0.3s ease;
}
/* Disable transition for SVG / animations */
svg *, canvas, video, img { transition: none !important; }

</style>
</head>
<body>
  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar">
    <a href="../../index.html">BeyonDegrees-UI</a>
    <span>/</span>
    <a href="#">Screens</a>
    <span>/</span>
    <span class="active">Quiz Card</span>
  </nav>

  <div class="page-layout">

    <!-- ===== MOBILE DEVICE FRAME ===== -->
    <div class="device-wrapper">
      <div class="device-frame">
        <div class="device-notch"></div>

        <div class="mobile-screen">

          <!-- Status Bar -->
          <div class="status-bar">
            <span class="status-time">9:41</span>
            <div class="status-right">
              <span>●●●</span>
              <span>WiFi</span>
              <span>🔋</span>
            </div>
          </div>

          <!-- Quiz Header: story bar + counter + score -->
          <header class="quiz-header">
            <div class="header-top">
              <button class="undo-btn" id="undoBtn" title="Hoàn tác">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 00-9-9 9 9 0 00-6 2.3L3 13"/></svg>
              </button>
              <div class="counter-wrap">
                <span class="counter-current" id="counterCurrent">7</span>
                <span class="counter-sep">/</span>
                <span class="counter-total">30</span>
              </div>
              <div class="mode-indicator" id="modeIndicator">
                <span class="mode-dot"></span>
                <span class="mode-label">Swipe</span>
              </div>
            </div>

            <!-- TikTok-style story bar -->
            <div class="story-bar" id="storyBar">
              <!-- 10 segments, filled by JS -->
            </div>

            <!-- Score row -->
            <div class="score-row">
              <div class="score-chip agree"><span>✓</span><span id="agreeCount">3</span></div>
              <div class="score-chip strong"><span>⚡</span><span id="strongCount">1</span></div>
              <div class="score-chip neutral"><span>–</span><span id="neutralCount">2</span></div>
              <div class="score-chip disagree"><span>✕</span><span id="disagreeCount">1</span></div>
            </div>
          </header>

          <!-- Card Arena -->
          <div class="card-arena" id="cardArena">

            <!-- Direction hints (shown on drag) -->
            <div class="dir-hint hint-right" id="hintRight">ĐỒNG Ý ✓</div>
            <div class="dir-hint hint-left" id="hintLeft">KHÔNG ĐỒNG Ý ✕</div>
            <div class="dir-hint hint-up" id="hintUp">RẤT ĐỒNG Ý ⚡</div>
            <div class="dir-hint hint-down" id="hintDown">TRUNG LẬP –</div>

            <!-- Card Stack -->
            <div class="card-stack" id="cardStack">
              <!-- Back card 2 -->
              <div class="q-card back-2" id="backCard2">
                <div class="card-inner">
                  <div class="card-placeholder">●●●</div>
                </div>
              </div>
              <!-- Back card 1 -->
              <div class="q-card back-1" id="backCard1">
                <div class="card-inner">
                  <div class="card-placeholder">●●●</div>
                </div>
              </div>
              <!-- Active card -->
              <div class="q-card active-card" id="activeCard">
                <!-- Drag overlay (color flash when swiping) -->
                <div class="drag-overlay" id="dragOverlay"></div>

                <div class="card-inner">
                  <div class="card-top-row">
                    <span class="discipline-tag" id="disciplineTag">⚡ Kỹ thuật</span>
                    <span class="q-number" id="qNumber">07</span>
                  </div>
                  <p class="q-text" id="qText">Tôi thích giải quyết vấn đề bằng cách phân tích dữ liệu hơn là dựa vào cảm xúc</p>

                  <!-- Spectrum mode UI (hidden by default) -->
                  <div class="spectrum-wrap" id="spectrumWrap">
                    <div class="spectrum-labels">
                      <span class="spec-label-left">Không đồng ý</span>
                      <span class="spec-label-right">Đồng ý</span>
                    </div>
                    <div class="spectrum-track" id="spectrumTrack">
                      <div class="spectrum-fill" id="spectrumFill"></div>
                      <div class="spectrum-thumb" id="spectrumThumb"></div>
                    </div>
                    <div class="spectrum-value-label" id="spectrumValueLabel">Trung lập</div>
                    <button class="spectrum-confirm-btn" id="spectrumConfirmBtn">Xác nhận ✓</button>
                  </div>

                  <!-- Swipe hint (shown when in swipe mode) -->
                  <div class="swipe-hint" id="swipeHint">
                    <span>Kéo để trả lời</span>
                    <span class="hint-arrows">← →</span>
                    <span class="hint-hold">Giữ để chọn mức độ</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Milestone overlay -->
            <div class="milestone-overlay" id="milestoneOverlay">
              <div class="milestone-content">
                <div class="milestone-emoji" id="milestoneEmoji">🔥</div>
                <div class="milestone-text" id="milestoneText">1/3 xong rồi!</div>
                <div class="milestone-sub" id="milestoneSub">Tiếp tục nhé →</div>
              </div>
            </div>

          </div><!-- /card-arena -->

          <!-- Footer shortcut hints -->
          <div class="quiz-footer">
            <div class="shortcut-row">
              <span class="sc sc-left">← Không đồng ý</span>
              <span class="sc sc-up">↑ Rất đồng ý</span>
              <span class="sc sc-down">↓ Trung lập</span>
              <span class="sc sc-right">→ Đồng ý</span>
            </div>
          </div>

        </div><!-- /mobile-screen -->
      </div><!-- /device-frame -->
    </div><!-- /device-wrapper -->

    <!-- ===== INFO PANEL ===== -->
    <aside class="info-panel">
      <div class="panel-section">
        <div class="panel-label">INTERACTION MODES</div>
        <div class="mode-card">
          <div class="mode-card-icon" style="background:rgba(6,214,160,0.1);color:var(--mint-500);">👆</div>
          <div>
            <div class="mode-card-title">Swipe nhanh</div>
            <div class="mode-card-desc">Kéo card theo 4 hướng. Thả qua ngưỡng 80px → bay luôn. Thả trước ngưỡng → spring back.</div>
          </div>
        </div>
        <div class="mode-card" style="margin-top:10px;">
          <div class="mode-card-icon" style="background:rgba(124,58,237,0.1);color:var(--violet-400);">✋</div>
          <div>
            <div class="mode-card-title">Hold 300ms → Spectrum</div>
            <div class="mode-card-desc">Giữ ngón tay/chuột không di chuyển → spectrum slider xuất hiện. Kéo để chọn mức độ chính xác từ -100 đến +100.</div>
          </div>
        </div>
      </div>

      <div class="panel-section">
        <div class="panel-label">SWIPE DIRECTIONS</div>
        <div class="dir-grid">
          <div class="dir-item"><span style="color:var(--mint-500)">→</span> Đồng ý</div>
          <div class="dir-item"><span style="color:var(--red-500)">←</span> Không đồng ý</div>
          <div class="dir-item"><span style="color:var(--violet-400)">↑</span> Rất đồng ý</div>
          <div class="dir-item"><span style="color:var(--neutral-300)">↓</span> Trung lập</div>
        </div>
      </div>

      <div class="panel-section">
        <div class="panel-label">LIVE DNA PROFILE</div>
        <div class="dna-bars" id="dnaBars">
          <div class="dna-row"><span class="dna-label">⚡ Kỹ thuật & CN</span><div class="dna-bar"><div class="dna-fill" style="width:40%;background:var(--violet-600)"></div></div><span class="dna-pct" id="dna-kt">40%</span></div>
          <div class="dna-row"><span class="dna-label">📚 Nhân văn</span><div class="dna-bar"><div class="dna-fill" style="width:28%;background:#3b82f6"></div></div><span class="dna-pct" id="dna-nv">28%</span></div>
          <div class="dna-row"><span class="dna-label">⚕️ Y & Sức khỏe</span><div class="dna-bar"><div class="dna-fill" style="width:20%;background:var(--mint-500)"></div></div><span class="dna-pct" id="dna-yt">20%</span></div>
          <div class="dna-row"><span class="dna-label">🌿 Nông nghiệp</span><div class="dna-bar"><div class="dna-fill" style="width:12%;background:var(--orange-500)"></div></div><span class="dna-pct" id="dna-nn">12%</span></div>
        </div>
        <p class="dna-note">Cập nhật real-time theo từng câu trả lời</p>
      </div>

      <div class="panel-section">
        <div class="panel-label">ANTIGRAVITY EXPERIMENT</div>
        <div class="exp-tag">A — Story-bar (TikTok style)</div>
        <div class="exp-tag" style="background:rgba(124,58,237,0.1);color:var(--violet-400);border-color:rgba(124,58,237,0.3);">B — Spring Physics Swipe</div>
        <div class="exp-tag" style="background:rgba(249,115,22,0.1);color:var(--orange-400);border-color:rgba(249,115,22,0.3);">NEW — Spectrum Tap</div>
      </div>
    </aside>

  </div><!-- /page-layout -->

  <!-- Toast -->
  <div class="bd-toast" id="bdToast"></div>

  <script src="../../scripts/utils.js"></script>
  <script src="../../scripts/navigation.js"></script>
  <script src="./quiz-card.js"></script>

<script>
(function() {
  function bdApplyTheme(resolved) {
    document.documentElement.setAttribute('data-theme', resolved);
    // Update toggle bg for light theme
    var toggle = document.getElementById('bd-theme-toggle');
    if (toggle) {
      toggle.style.background = (resolved === 'light')
        ? 'rgba(255,255,255,0.92)'
        : 'rgba(10,10,26,0.85)';
      toggle.style.borderColor = (resolved === 'light')
        ? 'rgba(24,99,220,0.25)'
        : 'rgba(24,99,220,0.35)';
    }
  }

  function bdSetTheme(pref) {
    var resolved = pref;
    if (pref === 'system') {
      resolved = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    }
    bdApplyTheme(resolved);
    document.documentElement.setAttribute('data-theme-pref', pref);
    try { localStorage.setItem('bd-theme', pref); } catch(e) {}
    // Update button active states
    var btns = { system:'bdt-system', light:'bdt-light', dark:'bdt-dark' };
    Object.keys(btns).forEach(function(name) {
      var el = document.getElementById(btns[name]);
      if (!el) return;
      if (name === pref) {
        el.style.background = 'linear-gradient(135deg,#1863DC,#0274BE)';
        el.style.color = '#fff';
        el.style.boxShadow = '0 4px 12px rgba(24,99,220,0.4)';
      } else {
        el.style.background = 'transparent';
        el.style.color = (resolved === 'light') ? 'rgba(26,26,46,0.55)' : 'rgba(255,255,255,0.5)';
        el.style.boxShadow = 'none';
      }
    });
  }

  window.bdSetTheme = bdSetTheme;

  // Init on load
  var saved = 'dark';
  try { saved = localStorage.getItem('bd-theme') || 'dark'; } catch(e) {}
  bdSetTheme(saved);

  // React to OS theme changes
  window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function() {
    var pref = document.documentElement.getAttribute('data-theme-pref') || 'dark';
    if (pref === 'system') bdSetTheme('system');
  });
})();
</script>

</body>
</html>