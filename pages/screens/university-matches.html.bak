<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>University Matches — BeyonDegrees.ai</title>
  <link rel="stylesheet" href="../../styles/tokens.css">
  <link rel="stylesheet" href="../../styles/base.css">
  <link rel="stylesheet" href="../../styles/components.css">
  <link rel="stylesheet" href="../../styles/animations.css">
  <link rel="stylesheet" href="../../styles/layout.css">
  <link rel="stylesheet" href="./university-matches.css">
</head>
<body>
<div class="breadcrumb"><a href="#" class="breadcrumb-item">BeyonDegrees-UI</a><span class="breadcrumb-separator">/</span><span class="breadcrumb-item active">University Matches</span></div>
<div class="desktop-container">
  <div class="device-frame"><div class="device-notch"></div>
    <div class="mobile-screen"><div class="us">
      <div class="us-aurora"></div>
      <div class="us-status"><span>9:41</span>
        <div style="display:flex;gap:6px;align-items:center">
          <svg width="14" height="10" viewBox="0 0 14 10" fill="currentColor"><rect x="0" y="3" width="2" height="7" rx="1"/><rect x="3" y="2" width="2" height="8" rx="1"/><rect x="6" y="0" width="2" height="10" rx="1"/><rect x="9" y="1" width="2" height="9" rx="1"/></svg>
          <svg width="16" height="10" viewBox="0 0 16 10" fill="currentColor"><rect x="1" y="1" width="11" height="8" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><rect x="2.5" y="2.5" width="7" height="5" rx="1"/><rect x="13" y="3" width="2" height="4" rx="1"/></svg>
        </div>
      </div>
      <div class="us-hdr">
        <div class="us-logo">Beyond<span>Degrees</span>.ai</div>
        <div style="width:30px;height:30px;border-radius:8px;background:var(--bg-surface);border:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </div>
      </div>
      <div class="us-body">
        <div class="us-hero">
          <div class="us-hero-arch">
            <svg viewBox="0 0 200 160" fill="none" style="width:85%;height:85%">
              <rect x="80" y="40" width="40" height="120" rx="2" fill="rgba(100,120,160,.38)"/>
              <rect x="85" y="20" width="30" height="28" rx="1" fill="rgba(100,120,160,.28)"/>
              <polygon points="100,2 116,20 84,20" fill="rgba(100,120,160,.55)"/>
              <rect x="20" y="68" width="55" height="92" rx="2" fill="rgba(80,100,140,.32)"/>
              <rect x="125" y="68" width="55" height="92" rx="2" fill="rgba(80,100,140,.32)"/>
              <rect x="30" y="84" width="8" height="12" rx="1" fill="rgba(6,214,160,.45)"/>
              <rect x="45" y="84" width="8" height="12" rx="1" fill="rgba(6,214,160,.45)"/>
              <rect x="60" y="84" width="8" height="12" rx="1" fill="rgba(6,214,160,.45)"/>
              <rect x="135" y="84" width="8" height="12" rx="1" fill="rgba(6,214,160,.45)"/>
              <rect x="150" y="84" width="8" height="12" rx="1" fill="rgba(6,214,160,.45)"/>
            </svg>
          </div>
          <div class="us-hero-ov"></div>
          <div class="us-hero-txt">
            <div class="us-hl">Best Universities<br>For You</div>
            <div class="us-sub2">Top institutions matching your academic profile,<br>Curated by our advanced matching engine.</div>
          </div>
        </div>
        <div class="us-content">
          <div class="ai-chip2">&#10022; AI Powered Matching</div>
          <div class="uc">
            <div class="uc-top">
              <div class="uc-lbox">&#127963;&#65039;</div>
              <div class="uc-info"><div class="uc-name">RMIT Vietnam</div><div class="uc-loc">Ho Chi Minh City, Vietnam</div></div>
              <div><div class="uc-pct">84%</div><div class="uc-plbl">Match</div></div>
            </div>
            <div class="uc-div"></div>
            <div class="uc-meta">
              <div><div class="mk">Annual tuition</div><div class="mv">$10k &ndash; $16k</div></div>
              <div><div class="mk">Financial Aid</div><div class="mv"><span class="aid full">&#10003; Full Scholarship</span></div></div>
            </div>
            <div class="uc-cta">View Programs &#8594;</div>
          </div>
          <div class="uc">
            <div class="uc-top">
              <div class="uc-lbox">&#127891;</div>
              <div class="uc-info"><div class="uc-name">Fulbright University</div><div class="uc-loc">Ho Chi Minh City, Vietnam</div></div>
              <div><div class="uc-pct">91%</div><div class="uc-plbl">Match</div></div>
            </div>
            <div class="uc-div"></div>
            <div class="uc-meta">
              <div><div class="mk">Annual tuition</div><div class="mv">$30,000</div></div>
              <div><div class="mk">Financial Aid</div><div class="mv"><span class="aid need">Need-Based Aid</span></div></div>
            </div>
            <div class="uc-cta">View Programs &#8594;</div>
          </div>
        </div>
      </div>
        <!-- ░░ PRESS-GLOW FLOATING TAB BAR ░░ -->
        <nav class="float-tab-bar" id="floatTabBar">

          <a href="./home-screen.html" class="tab-item" data-tab="t1">
            <span class="tab-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="8" r="3.5"/><path d="M4 21c0-3.5 3.1-6 7-6s7 2.5 7 6"/><path d="M19 2l.45 1.35L20.8 3.8l-1.35.45L19 5.6l-.45-1.35L17.2 3.8l1.35-.45z" fill="currentColor" stroke="none"/>
              </svg>
            </span>
            <span class="tab-label">About me</span>
          </a>
          <a href="./discipline-match.html" class="tab-item" data-tab="t2">
            <span class="tab-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"/><polygon points="16.24,7.76 14.12,14.12 7.76,16.24 9.88,9.88" stroke="none" fill="currentColor" opacity="0.6"/><circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>
              </svg>
            </span>
            <span class="tab-label">Disciplines</span>
          </a>
          <a href="./major-recommendations.html" class="tab-item" data-tab="t3">
            <span class="tab-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </span>
            <span class="tab-label">Majors</span>
          </a>
          <a href="./university-matches.html" class="tab-item active" data-tab="t4">
            <span class="tab-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11M20 10v11M8 14v3M12 14v3M16 14v3"/>
              </svg>
            </span>
            <span class="tab-label">Universities</span>
          </a>
          <a href="#" class="tab-item tab-disabled" data-tab="t5">
            <span class="tab-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="7.5" r="3.5"/><path d="M4.5 20.5c0-3.5 3.4-6.5 7.5-6.5s7.5 3 7.5 6.5"/><circle cx="19" cy="5" r="2.5" fill="currentColor" stroke="none" opacity="0.9"/><path d="M18 5l.7.7 1.3-1.4" stroke="var(--bg-base,#06060f)" stroke-width="1.4" fill="none" stroke-linecap="round"/>
              </svg>
            </span>
            <span class="tab-label">Hoàng Phúc</span>
          </a>
        </nav>
      </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>